FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY ["src/VetSysCli.Web/VetSysCli.Web.csproj", "src/VetSysCli.Web/"]
COPY ["src/VetSysCli.Application/VetSysCli.Application.csproj", "src/VetSysCli.Application/"]
RUN dotnet restore src/VetSysCli.Web/VetSysCli.Web.csproj

COPY . .
RUN dotnet publish src/VetSysCli.Web/VetSysCli.Web.csproj -c Release -o /app/publish

FROM nginx:alpine
COPY --from=build /app/publish/wwwroot /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

@page "/cadastro"
@inject HttpClient Http

<PageTitle>Cadastro</PageTitle>
<div class="page-header">
  <h2>Cadastro de animal</h2>
  <p>Registre as informações principais do paciente.</p>
</div>

<div class="card-panel mb-3">
  <div class="row g-3">
    <div class="col-md-6">
      <label class="form-label">Nome</label>
      <input class="form-control" @bind="name" />
    </div>
    <div class="col-md-6">
      <label class="form-label">Tipo</label>
      <input class="form-control" @bind="type" placeholder="Cachorro, Gato..." />
    </div>
    <div class="col-md-6">
      <label class="form-label">Raça</label>
      <input class="form-control" @bind="breed" />
    </div>
    <div class="col-md-6">
      <label class="form-label">Data de nascimento</label>
      <input class="form-control" type="date" @bind="birthDate" />
    </div>
    <div class="col-12">
      <label class="form-label">Características físicas</label>
      <textarea class="form-control" rows="3" @bind="physicalCharacteristics"></textarea>
    </div>
    <div class="col-12">
      <label class="form-label">Observações</label>
      <textarea class="form-control" rows="3" @bind="notes"></textarea>
    </div>
  </div>
  <div class="mt-3 d-flex gap-2">
    <button class="btn btn-primary" @onclick="Save">Salvar</button>
    <button class="btn btn-outline-secondary" @onclick="Clear">Limpar</button>
  </div>
  @if (!string.IsNullOrEmpty(message))
  {
    <p class="mt-3 mb-0">@message</p>
  }
</div>

@code {
  private string name = string.Empty;
  private string type = string.Empty;
  private string breed = string.Empty;
  private DateTime? birthDate;
  private string physicalCharacteristics = string.Empty;
  private string notes = string.Empty;
  private string message = string.Empty;

  private async Task Save()
  {
    var payload = new
    {
      ownerId = Guid.NewGuid(),
      name,
      type,
      breed,
      birthDate,
      physicalCharacteristics,
      notes
    };

    var response = await Http.PostAsJsonAsync("/api/animals", payload);
    message = response.IsSuccessStatusCode ? "Animal cadastrado com sucesso." : "Falha ao cadastrar.";
    if (response.IsSuccessStatusCode)
    {
      Clear();
    }
  }

  private void Clear()
  {
    name = string.Empty;
    type = string.Empty;
    breed = string.Empty;
    birthDate = null;
    physicalCharacteristics = string.Empty;
    notes = string.Empty;
    message = string.Empty;
  }
}
